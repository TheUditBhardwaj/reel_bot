# ── ReelMind AI Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in your values

# ── Core ──────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
PORT=8080

# ── Telegram Bot ──────────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Webhook URL (production only — leave empty for local polling)
WEBHOOK_URL=
WEBHOOK_SECRET=your_random_secret_string

# ── NVIDIA / Mistral AI ───────────────────────────────────────────────
# Get from https://build.nvidia.com/
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_MODEL=mistralai/mistral-large-3-675b-instruct-2512

# ── Whisper ───────────────────────────────────────────────────────────
# Options: tiny, base, small, medium, large
# 'base' recommended for Railway (low RAM), 'small' for better Hindi support
WHISPER_MODEL=base

# ── PostgreSQL ────────────────────────────────────────────────────────
# Railway provides this automatically via $DATABASE_URL
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/reelmind

# ── ChromaDB ──────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_data

# ── Notion (Optional) ────────────────────────────────────────────────
# Get from https://www.notion.so/my-integrations
NOTION_API_KEY=
NOTION_DATABASE_ID=

# ── yt-dlp ────────────────────────────────────────────────────────────
# Path to cookies.txt (exported from browser) for private reel access
COOKIE_FILE=
DOWNLOAD_DIR=/tmp/reelmind_downloads
